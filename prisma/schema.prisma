generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String   @id @default(uuid())
  username             String   @unique
  name                 String
  business             String
  email                String   @unique
  password             String
  createdAt            DateTime @default(now())

  // Per-client Vapi config (set by admin after onboarding)
  vapiAssistantId      String?
  vapiPhoneNumberId    String?

  // Stripe
  plan                 String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?

  // Dashboard profile (stored as JSON)
  profile              Json?
}
